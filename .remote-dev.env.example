# Copy to .remote-dev.env (gitignored) and set your own build host + paths.
# remote-dev runs the sandbox stack and on-device harnesses on a remote build
# box over SSH; nothing personal is baked into the committed tool.

# Required: SSH target for your build host (user@host or an ssh-config alias).
REMOTE_HOST=user@your-build-host
# Optional second host tried if REMOTE_HOST is unset (e.g. a LAN address).
REMOTE_FALLBACK_HOST=

# Remote workspace root holding SDK/ + sandbox/ (relative paths resolve to $HOME).
REMOTE_ROOT=honch-io

# Serial ports for on-device harnesses (as seen on the build host).
ESP32_PORT=/dev/ttyUSB0
PICO_PORT=/dev/ttyACM0
# Remote ESP-IDF install (only needed for the esp32 harness).
IDF_PATH=/opt/esp/esp-idf

# Optional explicit device-traffic host; if blank, derived from REMOTE_HOST.
DEVICE_HOST=

# Sandbox service ports.
CAPTURE_PORT=8001
WORKER_PORT=8082
PROXY_PORT=8080
CLICKHOUSE_NATIVE_PORT=19000
